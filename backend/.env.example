NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://smartclassroom:smartclassroom@localhost:5432/smart_classroom?schema=public
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=7d
JWT_ISSUER=smart-classroom-api
JWT_AUDIENCE=smart-classroom-app
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX=20
CLIENT_URL=http://localhost:3000
SEED_DEFAULT_PASSWORD=change_this_seed_password
